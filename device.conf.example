# ============================================================================
#  Per-device configuration for script.sh
#  Copy this file to "device.conf" (same folder as script.sh) and fill in
#  the values found using Section 8 of the install guide (README.md).
# ============================================================================

# Path to your Debian chroot root.
# Default, do not change this if you didnt installed another chroot
DEBIAN_ROOT="/data/local/debian"

# --- Composer HAL service name (README section 8.1) -----------------------
# Find via: lshal | grep -i composer  ->  ps -A | grep -i composer
#           -> cat /proc/<PID>/comm  -> grep -rl composer /vendor/etc/init/*.rc
# Common values: vendor.hwcomposer-2-3, vendor.hwcomposer-2-4,
#                vendor.qti.hardware.display.composer
# Set to "none" only if ps -A shows composer running as part of
# surfaceflinger itself (no separate process).
COMPOSER_SERVICE=""

# --- system_server touch-grab workaround (README section 8.2) -------------
# Set to 1 if "ps -A | grep system_server" still shows it running a few
# seconds after "stop zygote". Leave 0 otherwise.
KILL_SYSTEM_SERVER=

# --- Touchscreen calibration (README section 8.3 / 8.5) --------------------
# Leave both blank to skip calibration entirely (no rotation / no fix needed).
# TOUCH_DEVICE_NAME: exact "Input device name" from `evtest`, e.g. fts_ts,
#                     sec_touchscreen, synaptics_dsx, goodix_ts.
# CALIBRATION_MATRIX: 6 space-separated numbers, found by testing
#                      (see README section 8.5 table).
TOUCH_DEVICE_NAME=""
CALIBRATION_MATRIX=""

# --- Screen rotation (README section 8.4) -----------------------------------
# DRM_OUTPUT: exact output name from `wlr-randr`, e.g. DSI-1, eDP-1.
# SCREEN_TRANSFORM: one of normal, 90, 180, 270 (wlr-randr --transform value).
# Leave DRM_OUTPUT blank or SCREEN_TRANSFORM=normal to skip rotation.
DRM_OUTPUT=""
SCREEN_TRANSFORM="normal"

# --- Renderer ----------------------------------------------------------------
# pixman = software rendering (safest default, works everywhere).
# Change only if you've confirmed a GPU driver (e.g. panfrost, freedreno,
# turnip via zink) works on your device.
WLR_RENDERER="pixman"
